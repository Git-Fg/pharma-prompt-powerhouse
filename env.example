# =================================================================
# CONFIGURATION DE L'APPLICATION
# =================================================================

# URL de base de l'application (utilisée pour SEO, sitemap, robots.txt)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Configuration Vercel
NEXT_PUBLIC_VERCEL_URL=
VERCEL_URL=

# =================================================================
# AUTHENTIFICATION (SI NÉCESSAIRE)
# =================================================================

# NextAuth.js (si utilisation d'authentification)
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXTAUTH_SECRET=your-secret-key-here

# =================================================================
# APIS EXTERNES (SI NÉCESSAIRE)
# =================================================================

# APIs externes (si nécessaire)
# NEXT_PUBLIC_API_URL=https://api.example.com

# =================================================================
# ANALYTICS ET MONITORING
# =================================================================

# Analytics Vercel (optionnel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id

# Google Analytics (optionnel)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =================================================================
# DÉVELOPPEMENT
# =================================================================

# Niveau de logs pour le développement
NODE_ENV=development

# Désactiver la télémétrie Next.js (optionnel)
# NEXT_TELEMETRY_DISABLED=1
